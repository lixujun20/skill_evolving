        "name": "_shared_find_local_peaks",
        "description": "The common sub-task is identifying the indices of local peaks in a sequence that meet a specified threshold.",
        "source_skills": [
          "detect_local_peaks",
          "first_peak_after",
          "pair_nearby_peaks"
        ],
        "code": "def _shared_find_local_peaks(xs, threshold):\n    \"\"\"Return a list of indices of local peaks in xs that meet the threshold.\"\"\"\n    return [i for i in range(1, len(xs) - 1) if xs[i] > xs[i - 1] and xs[i] >= xs[i + 1] and xs[i] >= threshold]"
      },
      {
        "name": "_shared_normalize_title",
        "description": "The common sub-task is normalizing a string by converting it to lowercase, replacing non-alphanumeric characters with spaces, and collapsing whitespace.",
        "source_skills": [
          "normalize_reference_title",
          "dedupe_reference_titles",
          "titles_equivalent"
        ],
        "code": "def _shared_normalize_title(text):\n    \"\"\"Normalize text by lowercasing, replacing non-alphanumerics with spaces, and collapsing whitespace.\"\"\"\n    return \" \".join(\"\".join(ch if ch.isalnum() else \" \" for ch in text.lower()).split())"
      }
    ],
