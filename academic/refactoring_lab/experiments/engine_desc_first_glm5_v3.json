        "code": "def _shared_cross_product_2d(ux, uy, vx, vy):\n    \"\"\"Calculates the 2D cross product of vectors (ux, uy) and (vx, vy).\"\"\"\n    return ux * vy - uy * vx"
      },
      {
        "name": "_shared_det_2x2",
        "description": "Computing the determinant of a 2x2 matrix represented as a list of two rows.",
        "source_skills": [
          "det_2x2",
