          "solve_linear_2x2"
        ],
        "code": "def _shared_det_2x2(M):\n    \"\"\"Return the determinant of a 2x2 matrix M.\"\"\"\n    return M[0][0] * M[1][1] - M[0][1] * M[1][0]"
      },
      {
        "name": "_shared_gcd",
        "description": "All four skills perform the computation of the greatest common divisor (GCD) of two integers using the Euclidean algorithm.",
        "source_skills": [
          "gcd_pair",
          "lcm_of_list",
          "simplify_fraction",
          "count_coprime_pairs"
        ],
        "code": "def _shared_gcd(a, b):\n    \"\"\"Return the greatest common divisor of a and b using the Euclidean algorithm.\"\"\"\n    while b:\n        a, b = b, a % b\n    return a"
      },
      {
        "name": "_shared_pow_mod",
        "description": "The common sub-task is efficient modular exponentiation, specifically computing (base^exp) % mod using the binary exponentiation method.",
        "source_skills": [
          "pow_mod",
          "modular_inverse_prime",
          "binomial_mod_prime"
        ],
        "code": "def _shared_pow_mod(base, exp, mod):\n    \"\"\"Compute (base**exp) % mod using binary exponentiation.\"\"\"\n    result = 1\n    base %= mod\n    while exp > 0:\n        if exp & 1:\n            result = (result * base) % mod\n        base = (base * base) % mod\n        exp >>= 1\n    return result"
      },
